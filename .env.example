# Bling — token fixo (opcional se usar OAuth)
BLING_API_ACCESS_TOKEN=

# Bling OAuth (obrigatório para conectar via /api/bling/authorize)
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_REDIRECT_URI=https://catalogo-bs-distribuidora.vercel.app/api/bling/callback

# URL pública canônica do app (deve coincidir com o domínio Vercel e o Redirect URI do Bling)
NEXT_PUBLIC_APP_URL=https://catalogo-bs-distribuidora.vercel.app

# URL base da API v3 (opcional)
# BLING_API_BASE_URL=https://api.bling.com.br/Api/v3

# Supabase — persistência de clientes, solicitações e tokens Bling
# Use NEXT_PUBLIC_SUPABASE_URL (recomendado) ou SUPABASE_URL no servidor
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Webhook Bling — configure no painel do Bling a URL:
# https://catalogo-bs-distribuidora.vercel.app/api/bling/webhook
# A validação usa BLING_CLIENT_SECRET (header X-Bling-Signature-256).
